# Base autoconf cross-compile answers for i686-nanos (picolibc, 32-bit LE). A port's nxport.toml
# `cache` entries are appended to a copy of this. configure cannot run target programs, so these
# supply the run-test results that would otherwise hang/fail under cross.
ac_cv_sizeof_char=1
ac_cv_sizeof_short=2
ac_cv_sizeof_int=4
ac_cv_sizeof_long=4
ac_cv_sizeof_long_long=8
ac_cv_sizeof_void_p=4
ac_cv_sizeof_size_t=4
ac_cv_sizeof_off_t=8
ac_cv_c_bigendian=no
ac_cv_func_mmap_fixed_mapped=yes
ac_cv_func_malloc_0_nonnull=yes
ac_cv_func_realloc_0_nonnull=yes
